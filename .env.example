# LLM settings
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Embeddings: hf | openai
EMBEDDINGS_PROVIDER=hf
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval
RETRIEVAL_K=6
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Paths
PDF_DIR=data/raw_pdfs
VECTORSTORE_DIR=data/processed/vectorstore
